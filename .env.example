JWT_SECRET=replace-with-a-long-random-secret
CREDENTIAL_ENCRYPTION_KEY=
APP_ENV=production
WEB_PORT=8080
CORS_ORIGIN=http://localhost:8080
REGISTRATION_MODE=first-user
COOKIE_SECURE=auto
