{
  "name": "notavia",
  "version": "0.1.0-alpha.1",
  "description": "Private AI workspace for traceable creator assets and multi-platform writing",
  "license": "AGPL-3.0-only",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.9",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "@tiptap/pm": "3.26.1",
      "@tiptap/core": "3.26.1",
      "form-data": "4.0.6",
      "linkify-it": "5.0.1"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
