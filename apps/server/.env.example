# NovaNote Private Server Environment Variables
# Copy this file to .env and customize

# Server
PORT=3001

# Database: "sqlite" (default, zero-config) or "postgres"
DB_DRIVER=sqlite
DB_PATH=./data/notavia.db
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/notavia  # Uncomment for PostgreSQL

# Auth
JWT_SECRET=notavia-dev-secret-change-in-production

# AI (Ollama)
OLLAMA_URL=http://localhost:11434

# File uploads
UPLOAD_DIR=./data/uploads

# CORS
CORS_ORIGIN=http://localhost:5173
